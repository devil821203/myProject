{
  "manifest_version": 3,
  "name": "YouTube Auto Ad Skipper",
  "version": "3.0.0",
  "description": "使用 Chrome DevTools Protocol 偵測並點擊 YouTube 的略過廣告按鈕。",
  "permissions": [
    "storage",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "YouTube Auto Ad Skipper",
    "default_popup": "popup/popup.html"
  }
}
