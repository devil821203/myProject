{
  "manifest_version": 3,
  "name": "YouTube Auto Ad Skipper",
  "version": "2.1.0",
  "description": "偵測 YouTube 可略過廣告，並使用 Chrome Debugger API 自動略過。",
  "permissions": [
    "storage",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content_script/content.js"
      ],
      "css": [
        "content_script/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube Auto Ad Skipper",
    "default_popup": "popup/popup.html"
  }
}