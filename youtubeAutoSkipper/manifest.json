{
  "manifest_version": 3,
  "name": "YouTube Auto Ad Skipper",
  "version": "1.1.0",
  "description": "偵測 YouTube 廣告狀態，當廣告可略過時自動略過。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube Auto Ad Skipper",
    "default_popup": "popup.html"
  }
}